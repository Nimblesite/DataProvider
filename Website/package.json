{
  "name": "dataprovider-website",
  "version": "1.0.0",
  "description": "Documentation website for DataProvider - Effortless .NET Data Access",
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-readmes.cjs && node scripts/generate-api-docs.cjs && eleventy --serve",
    "build": "node scripts/copy-readmes.cjs && node scripts/generate-api-docs.cjs && eleventy",
    "generate-api": "node scripts/generate-api-docs.cjs",
    "docfx": "cd docfx && dotnet docfx metadata docfx.json",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium --with-deps"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-navigation": "^0.3.5",
    "@11ty/eleventy-plugin-rss": "^2.0.2",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "@playwright/test": "^1.47.0",
    "@types/node": "^25.6.0",
    "http-server": "^14.1.1",
    "markdown-it-anchor": "^9.2.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
